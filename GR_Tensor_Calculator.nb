================\>\"", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "coords", "]"}], ">=", "2"}], ",", 
