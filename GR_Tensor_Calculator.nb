          "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", "    ", 
        
        RowBox[{
        "Print", 
         "[", "\"\<Simplify[Ricci[[1, 1]]/B[r] + Ricci[[2, 2]]/A[r]] = \>\"", 
