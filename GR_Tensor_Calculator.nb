Notebook[{

Cell[CellGroupData[{
Cell["GR Tensor Calculator", "Title",ExpressionUUID->"b9e1d4f5-2027-41d5-bd55-dca2596636cd"],

Cell["\<\
Self-contained Wolfram Language notebook for computing standard geometric \
quantities from a metric tensor in general relativity.\
\>", "Text",ExpressionUUID->"af1915a9-73e3-4957-92f2-bad670543e51"],

Cell["Basic workflow for exam use:", "Text",ExpressionUUID->"15f55ad9-295e-4bee-bc53-939b77cf252a"],

Cell[TextData[{
 "1. Edit and evaluate the ",
 Cell[BoxData[Cell["USER INPUT SECTION",
   Background->None,ExpressionUUID->"cdee2e10-0fb0-4822-9456-5dca0ef93922"]], 
  "InlineCode",ExpressionUUID->"c5bd5034-c6ed-42ba-a2a3-0b78a4953192"],
 "."
}], "Text",ExpressionUUID->"652b25bd-c4f1-49d6-acac-75f028d95894"],

Cell[TextData[{
 "2. Evaluate the single code cell in the ",
 Cell[BoxData[Cell["OUTPUT SECTION",
   Background->None,ExpressionUUID->"5b4c7fa3-7916-42d3-92d0-1b39b275a6fc"]], 
  "InlineCode",ExpressionUUID->"0b2b45b3-04ed-4632-b30b-ae13fd3d9144"],
 "."
}], "Text",ExpressionUUID->"1b8e227d-167a-415a-a820-509afeafbf48"],

Cell[TextData[{
 "The ",
 Cell[BoxData[Cell["OUTPUT SECTION",
   Background->None,ExpressionUUID->"58c778c1-a72b-48df-8d6a-a0718d7c285d"]], 
  "InlineCode",ExpressionUUID->"0e269278-9977-4b7d-9b9a-62a4412d668d"],
 " is intentionally self-contained: it defines the tensor functions, computes \
all tensors fresh, and prints the requested results."
}], "Text",ExpressionUUID->"30e79da1-1841-49db-9eb7-16b7dbc049b6"],

Cell["Index conventions: ", "Text",ExpressionUUID->"6b5c86f7-9120-4983-bbaf-19d457dc067b"],

Cell[TextData[{
 Cell[BoxData[Cell["Christoffel[[rho, mu, nu]]",
   Background->None,ExpressionUUID->"bd417a32-40eb-4f87-89c1-791d4d0a65e5"]], 
  "InlineCode",ExpressionUUID->"f97e62bc-2a98-4d89-b0c4-55e7b63cb2b1"],
 " means ",
 Cell[BoxData[Cell["Gamma^rho_{mu nu}",
   Background->None,ExpressionUUID->"9af385d2-8a70-4974-8032-0b46b903b009"]], 
  "InlineCode",ExpressionUUID->"719b7c9d-f29d-420e-bf1a-887926028bca"],
 "."
}], "Item",ExpressionUUID->"ae54d143-f525-4a01-ac31-03726f0e26c7"],

Cell[TextData[{
 Cell[BoxData[Cell["Riemann[[rho, sigma, mu, nu]]",
   Background->None,ExpressionUUID->"d68d0356-66d3-40a7-a0c7-08695c695f83"]], 
  "InlineCode",ExpressionUUID->"2dae659f-b287-48bb-838c-e0d888523cb0"],
 " means ",
 Cell[BoxData[Cell["R^rho_{sigma mu nu}",
   Background->None,ExpressionUUID->"a0935abf-55d6-4f2c-a2bd-d1c546e770ae"]], 
  "InlineCode",ExpressionUUID->"c77cc0e9-3b97-4308-9cf1-52bb3fc51cf8"],
 "."
}], "Item",ExpressionUUID->"39be2d15-329f-4a4d-a2bb-d092da8d3bc9"],

Cell[TextData[{
 Cell[BoxData[Cell["Ricci[[mu, nu]]",
   Background->None,ExpressionUUID->"34a34408-89df-423f-877a-906559ad73aa"]], 
  "InlineCode",ExpressionUUID->"557dec96-60f9-41d9-ae63-d12f7056b281"],
 " means ",
 Cell[BoxData[Cell["R_{mu nu}",
   Background->None,ExpressionUUID->"81b7b65b-6eea-4dd0-bd19-f5c1893233a7"]], 
  "InlineCode",ExpressionUUID->"c455fe80-b266-4295-8fb6-4016909efebb"],
 "."
}], "Item",ExpressionUUID->"7d9456f6-2b9e-4c5b-9469-15a6ab114b46"],

Cell["Riemann convention used here: ", "Text",ExpressionUUID->"f4171b55-1549-4c9c-8141-f932ff7bd737"],

Cell["\<\
R^rho_{sigma mu nu} = partial_mu Gamma^rho_{nu sigma} - partial_nu \
Gamma^rho_{mu sigma} + Gamma^rho_{mu lambda} Gamma^lambda_{nu sigma} - \
Gamma^rho_{nu lambda} Gamma^lambda_{mu sigma}.\
\>", "Program",ExpressionUUID->"1c82a2ab-36ca-4068-8d5f-1c3a4460fa63"],

Cell["Ricci contraction used here: ", "Text",ExpressionUUID->"5d65fe9e-dae0-4fa2-a6a0-1a7e095a5e81"],

Cell["R_{mu nu} = R^rho_{mu rho nu}.", "Program",ExpressionUUID->"45cf1631-d112-49d3-a0ee-1303da13f603"],

Cell[CellGroupData[{

Cell["USER INPUT SECTION", "Section",ExpressionUUID->"566f2f3f-d231-4be7-8ba4-f59083429577"],

Cell["\<\
Edit this cell during an exam. The default example is a non-static \
Robertson-Walker/FLRW metric with scale factor a[t]. \
\>", "Text",ExpressionUUID->"38b558f3-efff-46f4-a4b9-545fa039325c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "t", ",", "r", ",", "th", ",", "ph", ",", "A", ",", "B", ",", " ", "M", ",",
