 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ValidateTensorInput", "[", 
     RowBox[{"metric_", ",", "coords_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", ",", "dims"}], "}"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", "  ", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"!", " ", 
           RowBox[{"ListQ", "[", "coords", "]"}]}], "||", 
          RowBox[{
           RowBox[{"Length", "[", "coords", "]"}], "==", "0"}]}], ",", 
         "\[IndentingNewLine]", "    ", 
         RowBox[{
          RowBox[{
          "Print", 
           "[", "\"\<ERROR: coords must be a nonempty list, for example {t, \
r, th, ph}.\>\"", "]"}], ";", "\[IndentingNewLine]", "    ", 
          RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], 
        "\[IndentingNewLine]", "  ", "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "  ", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "coords", "]"}]}], ";", "\[IndentingNewLine]", 
       "  ", 
       RowBox[{"dims", "=", 
        RowBox[{"Dimensions", "[", "metric", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"!", " ", 
           RowBox[{"MatrixQ", "[", "metric", "]"}]}], "||", 
          RowBox[{"dims", "=!=", 
           RowBox[{"{", 
            RowBox[{"n", ",", "n"}], "}"}]}]}], ",", "\[IndentingNewLine]", 
         "    ", 
         RowBox[{
          RowBox[{
          "Print", 
           "[", "\"\<ERROR: metric must be an n x n matrix with n = \
Length[coords].\>\"", "]"}], ";", "\[IndentingNewLine]", "    ", 
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<Dimensions[metric] = \>\"", ",", "dims", 
            ",", "\"\<, expected \>\"", ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "n"}], "}"}], ",", "\"\<.\>\""}], "]"}], ";", 
          "\[IndentingNewLine]", "    ", 
          RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], 
        "\[IndentingNewLine]", "  ", "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "  ", "True"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ComponentName", "[", 
     RowBox[{"label_", ",", "tuple_", ",", "coords_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"names", "=", 
        RowBox[{
         RowBox[{
