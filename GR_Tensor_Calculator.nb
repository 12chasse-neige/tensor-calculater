 RowBox[{
  RowBox[{
   RowBox[{
   "ToExpression", 
    "[", "\"\<ComputeKretschmannFromRiemann[metric_, riemann_] := Module[{n = \
Length[metric], inverseMetricLocal}, If[! MatrixQ[metric] || \
Dimensions[metric] =!= {n, n}, Return[$Failed]]; If[Dimensions[riemann] =!= \
{n, n, n, n}, Return[$Failed]]; inverseMetricLocal = \
FullSimplify[Inverse[metric]]; FullSimplify[Sum[metric[[rhoIdx, \
alphaIdx]]*inverseMetricLocal[[sigmaIdx, betaIdx]]*inverseMetricLocal[[muIdx, \
gammaIdx]]*inverseMetricLocal[[nuIdx, deltaIdx]]*riemann[[alphaIdx, sigmaIdx, \
muIdx, nuIdx]]*riemann[[rhoIdx, betaIdx, gammaIdx, deltaIdx]], {rhoIdx, n}, \
{alphaIdx, n}, {sigmaIdx, n}, {betaIdx, n}, {muIdx, n}, {gammaIdx, n}, \
{nuIdx, n}, {deltaIdx, n}]]]; ComputeKretschmann[metric_, coords_] := \
Module[{riemann}, If[ValidateTensorInput[metric, coords] === $Failed, \
Return[$Failed]]; riemann = ComputeRiemann[metric, coords]; If[riemann === \
$Failed, Return[$Failed]]; ComputeKretschmannFromRiemann[metric, riemann]];\>\
\"", "]"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
