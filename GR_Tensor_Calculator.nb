        "\[IndentingNewLine]", "    ", 
        RowBox[{"Print", "[", "schwarzschildExpected", "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", "    ", 
        RowBox[{"Print", "[", 
